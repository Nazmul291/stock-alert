generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String    @unique
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?   @db.VarChar(255)
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
  plan          Plan?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  storeSettings          StoreSettings?
  inventoryTracking      InventoryTracking[]
  alertHistory           AlertHistory[]
  setupProgress          SetupProgress?
  backInStockSubscribers BackInStockSubscriber[]

  @@index([plan])
}

enum Plan {
  basic
  pro
  enterprise
}

enum AlertType {
  low_stock
  out_of_stock
  restock
}

enum InventoryStatus {
  in_stock
  low_stock
  out_of_stock
  deactivated
}

model StoreSettings {
  id                   String   @id @default(uuid()) @db.Uuid
  shop                 String   @unique
  lowStockThreshold    Int      @default(5) @map("low_stock_threshold")
  autoHideEnabled      Boolean  @default(false) @map("auto_hide_enabled")
  emailNotifications   Boolean  @default(true) @map("email_notifications")
  slackNotifications   Boolean  @default(false) @map("slack_notifications")
  notificationEmail    String?  @map("notification_email")
  slackWebhookUrl      String?  @map("slack_webhook_url")
  autoRepublishEnabled Boolean   @default(false) @map("auto_republish_enabled")
  digestEnabled        Boolean   @default(true) @map("digest_enabled")
  digestFrequency      String    @default("weekly") @map("digest_frequency")
  lastDigestSentAt     DateTime? @map("last_digest_sent_at") @db.Timestamptz
  brandLogoUrl         String?   @map("brand_logo_url") @db.VarChar(500)
  brandColor           String?   @map("brand_color") @db.VarChar(7)
  brandSenderName      String?   @map("brand_sender_name") @db.VarChar(100)
  outboundWebhookUrl   String?   @map("outbound_webhook_url") @db.VarChar(500)
  supplierLeadTimeDays Int       @default(7) @map("supplier_lead_time_days")
  monitoringFilter     String    @default("all") @map("monitoring_filter")
  monitoringCollectionId String? @map("monitoring_collection_id") @db.VarChar(50)
  monitoringTags         String?  @map("monitoring_tags") @db.VarChar(500)
  whatsappNotifications  Boolean  @default(false) @map("whatsapp_notifications")
  whatsappPhone          String?  @map("whatsapp_phone") @db.VarChar(30)
  whatsappPhoneNumberId  String?  @map("whatsapp_phone_number_id") @db.VarChar(50)
  whatsappAccessToken    String?  @map("whatsapp_access_token") @db.VarChar(500)
  klaviyoEnabled         Boolean  @default(false) @map("klaviyo_enabled")
  klaviyoApiKey          String?  @map("klaviyo_api_key") @db.VarChar(500)
  slackTeamName          String?  @map("slack_team_name") @db.VarChar(200)
  slackChannelName       String?  @map("slack_channel_name") @db.VarChar(200)
  slackAccessToken       String?  @map("slack_access_token") @db.VarChar(500)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  session Session @relation(fields: [shop], references: [shop], onDelete: Cascade)

  @@index([shop])
  @@map("store_settings")
}

model InventoryTracking {
  id               String          @id @default(uuid()) @db.Uuid
  shop             String
  productId        BigInt          @map("product_id")
  productTitle     String?         @map("product_title") @db.VarChar(500)
  variantTitle     String?         @map("variant_title") @db.VarChar(500)
  sku              String?         @db.VarChar(255)
  currentQuantity  Int             @default(0) @map("current_quantity")
  previousQuantity Int?            @map("previous_quantity")
  lastCheckedAt    DateTime        @default(now()) @map("last_checked_at") @db.Timestamptz
  lastAlertSentAt  DateTime?       @map("last_alert_sent_at") @db.Timestamptz
  lastAlertType    AlertType?      @map("last_alert_type")
  isHidden           Boolean         @default(false) @map("is_hidden")
  monitoringEnabled  Boolean         @default(true) @map("monitoring_enabled")
  inventoryStatus    InventoryStatus @default(in_stock) @map("inventory_status")
  avgDailySales        Float?    @map("avg_daily_sales")
  stockOutDays         Int?      @map("stock_out_days")
  manualDailySales     Float?    @map("manual_daily_sales")
  expectedRestockDate  DateTime? @map("expected_restock_date") @db.Timestamptz
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  session Session @relation(fields: [shop], references: [shop], onDelete: Cascade)

  @@unique([shop, productId])
  @@index([shop])
  @@index([shop, currentQuantity])
  @@index([shop, isHidden])
  @@index([lastCheckedAt])
  @@index([shop, lastAlertSentAt])
  @@index([shop, inventoryStatus])
  @@map("inventory_tracking")
}

model AlertHistory {
  id                 String     @id @default(uuid()) @db.Uuid
  shop               String
  productId          BigInt?    @map("product_id")
  productTitle       String?    @map("product_title") @db.VarChar(500)
  alertType          AlertType? @map("alert_type")
  quantityAtAlert    Int?       @map("quantity_at_alert")
  thresholdTriggered Int?       @map("threshold_triggered")
  sentToEmail        String?    @map("sent_to_email") @db.VarChar(255)
  sentToSlack        Boolean    @default(false) @map("sent_to_slack")
  sentAt             DateTime   @default(now()) @map("sent_at") @db.Timestamptz
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz

  session Session @relation(fields: [shop], references: [shop], onDelete: Cascade)

  @@index([shop])
  @@index([sentAt(sort: Desc)])
  @@index([shop, sentAt(sort: Desc)])
  @@map("alert_history")
}

model SetupProgress {
  id                          String   @id @default(uuid()) @db.Uuid
  shop                        String   @unique
  appInstalled                Boolean  @default(true) @map("app_installed")
  globalSettingsConfigured    Boolean  @default(false) @map("global_settings_configured")
  notificationsConfigured     Boolean  @default(false) @map("notifications_configured")
  productThresholdsConfigured Boolean  @default(false) @map("product_thresholds_configured")
  firstProductTracked         Boolean  @default(false) @map("first_product_tracked")
  createdAt                   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  session Session @relation(fields: [shop], references: [shop], onDelete: Cascade)

  @@index([shop])
  @@map("setup_progress")
}




// Per-shop sync progress — persisted so all web VMs see the same state.
model SyncState {
  shop          String    @id
  running       Boolean   @default(false)
  progress      Int       @default(0)
  startedAt     DateTime  @map("started_at") @db.Timestamptz
  completedAt   DateTime? @map("completed_at") @db.Timestamptz
  syncedCount   Int?      @map("synced_count")
  error         String?
  lastWebhookAt DateTime? @map("last_webhook_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("sync_state")
}

// Transient debounce buffer — rows are deleted after the alert fires.
// No FK relation to Session so cascades don't interfere with rapid writes.
model InventoryBuffer {
  id        String   @id @default(cuid())
  eventKey  String   @unique // "{productId}_{shop}_{alertType}"
  shop      String
  productId String
  alertType String   // "low_stock" | "out_of_stock"
  payload   Json     // Full notification context; overwritten on each upsert
  jobId     String?  // pg-boss job ID of the current pending debounce job
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([shop])
  @@index([updatedAt])
  @@map("inventory_buffer")
}

enum AdminRole {
  ADMIN
  SUPPORT_AGENT
}

enum ChatStatus {
  OPEN
  ENDED
}

enum ChatSender {
  MERCHANT
  ADMIN
  BOT
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         AdminRole @default(SUPPORT_AGENT)
  isActive     Boolean   @default(true)
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())

  assignedChats ChatConversation[]

  @@map("admin_users")
}

// NOTE: Add a relation to your Shop model if you want shop-level cascades:
//   shop     Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
// Otherwise remove the `shop` field and use shopId as a plain string.

model ChatConversation {
  id            String        @id @default(cuid())
  shopId        String
  merchantEmail String?
  status        ChatStatus    @default(OPEN)
  startedAt     DateTime      @default(now())
  endedAt       DateTime?
  assignedToId  String?
  assignedTo    AdminUser?    @relation(fields: [assignedToId], references: [id])
  messages      ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         ChatSender
  text           String
  sentAt         DateTime         @default(now())

  @@map("chat_messages")
}

model BackInStockSubscriber {
  id           String    @id @default(uuid()) @db.Uuid
  shop         String
  productId    BigInt    @map("product_id")
  productTitle String?   @map("product_title") @db.VarChar(500)
  email        String    @db.VarChar(255)
  firstName    String?   @map("first_name") @db.VarChar(100)
  lastName     String?   @map("last_name") @db.VarChar(100)
  subscribedAt DateTime  @default(now()) @map("subscribed_at") @db.Timestamptz
  notifiedAt   DateTime? @map("notified_at") @db.Timestamptz

  session Session @relation(fields: [shop], references: [shop], onDelete: Cascade)

  @@unique([shop, productId, email])
  @@index([shop])
  @@index([shop, productId])
  @@map("back_in_stock_subscribers")
}
